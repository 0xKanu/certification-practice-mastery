# ── Provider Switch ──────────────────────────────────────
# Set PROVIDER to "openrouter" or "nvidia" to switch backends.
# Then set the matching API key and model below.
PROVIDER=nvidia

# ── OpenRouter Config ────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
MODEL=meta-llama/llama-3.3-70b-instruct

# ── Nvidia NIM Config ────────────────────────────────────
NVIDIA_API_KEY=nvapi-...
NVIDIA_MODEL=meta/llama-3.3-70b-instruct